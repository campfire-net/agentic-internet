{
  "convention": "operator-provenance",
  "version": "0.1",
  "operation": "operator-revoke",
  "description": "Revoke a prior operator provenance attestation",
  "produces_tags": [
    {"tag": "provenance:revoke", "cardinality": "exactly_one"}
  ],
  "antecedents": "exactly_one(target)",
  "args": [
    {"name": "attestation_id", "type": "message_id", "required": true, "description": "The attestation message being revoked"},
    {"name": "reason", "type": "string", "required": false, "max_length": 280, "description": "Why the attestation is being revoked"}
  ],
  "payload_required": true,
  "signing": "member_key",
  "min_operator_level": 0
}
