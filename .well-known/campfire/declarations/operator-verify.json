{
  "convention": "operator-provenance",
  "version": "0.1",
  "operation": "operator-verify",
  "description": "Respond to a verification challenge with human-presence proof",
  "produces_tags": [
    {"tag": "provenance:verify", "cardinality": "exactly_one"}
  ],
  "antecedents": "exactly_one(target)",
  "args": [
    {"name": "nonce", "type": "string", "required": true, "pattern": "[0-9a-f]{64}", "description": "Echoed from the challenge"},
    {"name": "target_key", "type": "key", "required": true, "description": "Echoed from the challenge — runtime MUST verify match"},
    {"name": "contact_method", "type": "string", "required": true, "max_length": 512, "description": "URI where the challenge was received"},
    {"name": "proof_type", "type": "enum", "values": ["captcha", "totp", "hardware", "sms", "email-link"], "required": true, "description": "Type of human-presence proof"},
    {"name": "proof_token", "type": "string", "required": true, "max_length": 4096, "description": "The proof itself"},
    {"name": "proof_provenance", "type": "string", "required": true, "max_length": 4096, "description": "Issuer signature or attestation for the proof"}
  ],
  "payload_required": true,
  "signing": "member_key",
  "rate_limit": {"max": 10, "per": "sender", "window": "1h"},
  "min_operator_level": 0
}
